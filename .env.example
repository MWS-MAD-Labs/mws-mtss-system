# ─────────────────────────────────────────────────────────
# mws-mtss-system — Environment Variables Template
# Copy to .env and fill in actual values
# In Komodo: define these in Stack → Environment Variables
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3004

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=<generate-with: openssl rand -hex 64>
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=<from-google-cloud-console>
GOOGLE_CLIENT_SECRET=<from-google-cloud-console>
GOOGLE_REDIRECT_URL=https://mtss-stg.mws.web.id/auth/google/callback
SESSION_SECRET=<generate-with: openssl rand -hex 32>

# Google AI (for MTSS emotional analysis)
GOOGLE_AI_API_KEY=<from-google-ai-studio>
GOOGLE_AI_MODEL=gemini-flash-latest
GOOGLE_AI_FALLBACK_MODEL=gemini-1.5-flash
AI_ANALYSIS_ENABLED=true

# OpenRouter / AgentRouter (for AI Chat assistant)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-8b:free
OPENROUTER_FALLBACK_MODELS=meta-llama/llama-4-scout:free,deepseek/deepseek-r1-0528:free
OPENROUTER_APP_NAME=IntegraLearn AI Chat
OPENROUTER_MAX_TOKENS=1024
OPENROUTER_TEMPERATURE=0.4
OPENROUTER_TIMEOUT_MS=30000

AGENT_ROUTER_TOKEN=<agent-router-token>
AGENT_ROUTER_BASE_URL=https://agentrouter.org/v1
AGENT_ROUTER_MODEL=glm-4.6

# Cloudinary
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# Frontend URL (used for OAuth callback, Slack deep-links)
FRONTEND_URL=https://mtss-stg.mws.web.id

# CORS — allowed origins
CORS_ORIGINS=https://mtss-stg.mws.web.id

# Slack (for MTSS teacher notifications)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=<from-slack-app-settings>

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@millennia21.id
SMTP_PASS=<app-password>
SMTP_FROM=no-reply@millennia21.id

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=600
